    "# ── TASK 1: Historical VaR (95%) & CVaR ──────────\n",
    "# VaR = 5th percentile of daily returns\n",
    "# CVaR = mean of returns BELOW VaR threshold\n",
    "\n",
    "var_data = []\n",
    "\n",
    "for fund_code in nav_returns[\"scheme_code\"].unique():\n",
    "    fund_data = nav_returns[nav_returns[\"scheme_code\"] == fund_code]\n",
    "    scheme_name = fund_data[\"scheme_name\"].iloc[0]\n",
    "    risk_grade  = fund_data[\"risk_grade\"].iloc[0]\n",
    "    \n",
    "    returns = fund_data[\"daily_return\"].values\n",
    "    \n",
    "    # VaR at 95% confidence\n",
    "    var_95 = np.percentile(returns, 5)\n",
    "    \n",
    "    # CVaR = mean of returns below VaR\n",
    "    cvar_95 = returns[returns <= var_95].mean()\n",
    "    \n",
    "    var_data.append({\n",
    "        \"scheme_code\":   fund_code,\n",
    "        \"scheme_name\":   scheme_name,\n",
    "        \"risk_grade\":    risk_grade,\n",
    "        \"var_95_%\":      round(var_95 * 100, 4),\n",
    "        \"cvar_95_%\":     round(cvar_95 * 100, 4),\n",
    "        \"total_days\":    len(returns),\n",
    "    })\n",
    "\n",
    "var_df = pd.DataFrame(var_data).sort_values(\"var_95_%\")\n",
    "\n",
    "print(\"✅ VaR & CVaR computed!\")\n",
    "print(\"\\n📊 VaR & CVaR Report (Worst = Most Negative):\")\n",
    "print(var_df.to_string(index=False))\n",
    "\n",
    "# Save report\n",
    "var_df.to_csv(str(BASE / \"var_cvar_report.csv\"), index=False)\n",
    "print(\"\\n💾 Saved to var_cvar_report.csv\")\n",
    "\n",
    "# Plot VaR chart\n",
    "plt.figure(figsize=(12, 5))\n",
    "colors = [\"red\" if v < -1.5 else \"orange\" if v < -1.0 else \"green\"\n",
    "          for v in var_df[\"var_95_%\"]]\n",
    "plt.barh(var_df[\"scheme_name\"], var_df[\"var_95_%\"], color=colors)\n",
    "plt.axvline(x=0, color=\"black\", linestyle=\"--\", linewidth=0.8)\n",
    "plt.title(\"📉 Value at Risk (95%) — All Funds\", fontsize=13)\n",
    "plt.xlabel(\"VaR % (Daily)\")\n",
    "plt.ylabel(\"Fund\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(str(CHARTS / \"var_chart.png\"), dpi=150)\n",
    "plt.show()\n",
    "print(\"✅ VaR chart saved!\")"
   ]
