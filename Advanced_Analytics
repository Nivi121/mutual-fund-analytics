    "# ── TASK 2: Rolling 90-Day Sharpe Ratio ──────────\n",
    "RF_DAILY = 0.065 / 252  # Daily risk-free rate\n",
    "\n",
    "# Pick 5 key funds\n",
    "top5_funds = [119551, 120503, 118632, 119092, 125497]\n",
    "top5_names = {\n",
    "    119551: \"SBI Bluechip\",\n",
    "    120503: \"ICICI Bluechip\",\n",
    "    118632: \"Nippon Large Cap\",\n",
    "    119092: \"Axis Bluechip\",\n",
    "    125497: \"HDFC Top 100\",\n",
    "}\n",
    "\n",
    "plt.figure(figsize=(14, 6))\n",
    "\n",
    "for fund_code in top5_funds:\n",
    "    fund_data = nav_returns[nav_returns[\"scheme_code\"] == fund_code].sort_values(\"nav_date\")\n",
    "    scheme_name = top5_names[fund_code]\n",
    "\n",
    "    returns = fund_data.set_index(\"nav_date\")[\"daily_return\"]\n",
    "\n",
    "    # Rolling 90-day Sharpe\n",
    "    rolling_mean = returns.rolling(90).mean()\n",
    "    rolling_std  = returns.rolling(90).std()\n",
    "    rolling_sharpe = (rolling_mean - RF_DAILY) / rolling_std * np.sqrt(252)\n",
    "\n",
    "    plt.plot(rolling_sharpe.index, rolling_sharpe.values,\n",
    "             label=scheme_name, linewidth=1.5)\n",
    "\n",
    "plt.axhline(y=0, color=\"black\", linestyle=\"--\", linewidth=0.8)\n",
    "plt.title(\"📈 Rolling 90-Day Sharpe Ratio — Top 5 Funds\", fontsize=13)\n",
    "plt.xlabel(\"Date\")\n",
    "plt.ylabel(\"Sharpe Ratio\")\n",
