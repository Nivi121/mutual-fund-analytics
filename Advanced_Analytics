    "# ── TASK 4: SIP Continuity Analysis ──────────────\n",
    "# Find investors with 6+ SIP transactions\n",
    "# Flag those with gap > 35 days as \"at-risk\"\n",
    "\n",
    "# Filter SIP transactions only\n",
    "sip_txns = txn[txn[\"txn_type\"] == \"SIP\"].copy()\n",
    "sip_txns = sip_txns.sort_values([\"scheme_code\", \"txn_date\"])\n",
    "\n",
    "# Count SIP transactions per scheme\n",
    "sip_counts = sip_txns.groupby(\"scheme_code\")[\"transaction_id\"].count().reset_index()\n",
    "sip_counts.columns = [\"scheme_code\", \"sip_count\"]\n",
    "\n",
    "# Get schemes with 6+ SIPs\n",
    "active_sips = sip_counts[sip_counts[\"sip_count\"] >= 6][\"scheme_code\"].tolist()\n",
    "\n",
    "continuity_data = []\n",
    "\n",
    "for code in active_sips:\n",
    "    fund_sips = sip_txns[sip_txns[\"scheme_code\"] == code].sort_values(\"txn_date\")\n",
    "    scheme_name = funds[funds[\"scheme_code\"] == code][\"scheme_name\"].iloc[0]\n",
    "\n",
    "    # Compute gaps between SIP dates\n",
    "    dates = fund_sips[\"txn_date\"].values\n",
    "    gaps  = [(pd.Timestamp(dates[i]) - pd.Timestamp(dates[i-1])).days\n",
    "             for i in range(1, len(dates))]\n",
    "\n",
    "    avg_gap = np.mean(gaps) if gaps else 0\n",
    "    max_gap = np.max(gaps) if gaps else 0\n",
    "    status  = \"⚠️ At-Risk\" if avg_gap > 35 else \"✅ Regular\"\n",
    "\n",
    "    continuity_data.append({\n",
    "        \"scheme_code\":  code,\n",
    "        \"scheme_name\":  scheme_name,\n",
    "        \"sip_count\":    len(fund_sips),\n",
    "        \"avg_gap_days\": round(avg_gap, 1),\n",
    "        \"max_gap_days\": max_gap,\n",
    "        \"status\":       status,\n",
    "    })\n",
    "\n",
    "cont_df = pd.DataFrame(continuity_data).sort_values(\"avg_gap_days\", ascending=False)\n",
    "\n",
    "print(\"✅ SIP Continuity Analysis complete!\")\n",
    "print(\"\\n📊 SIP Continuity Report:\")\n",
    "print(cont_df.to_string(index=False))\n",
    "\n",
    "# Count at-risk vs regular\n",
    "at_risk  = (cont_df[\"status\"] == \"⚠️ At-Risk\").sum()\n",
    "regular  = (cont_df[\"status\"] == \"✅ Regular\").sum()\n",
    "print(f\"\\n  ⚠️  At-Risk funds  : {at_risk}\")\n",
    "print(f\"  ✅  Regular funds  : {regular}\")\n",
    "\n",
    "# Save\n",
    "cont_df.to_csv(str(BASE / \"sip_continuity.csv\"), index=False)\n",
    "print(\"\\n💾 Saved to sip_continuity.csv\")"
   ]
