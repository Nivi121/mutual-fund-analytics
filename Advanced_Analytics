    "# ── TASK 6: Sector HHI Concentration ─────────────\n",
    "# HHI = Σ(weight_i²) per fund\n",
    "# Higher HHI = more concentrated portfolio\n",
    "\n",
    "hhi_data = []\n",
    "\n",
    "for fund_code in holdings[\"scheme_code\"].unique():\n",
    "    fund_holdings = holdings[holdings[\"scheme_code\"] == fund_code]\n",
    "    scheme_name   = funds[funds[\"scheme_code\"] == fund_code][\"scheme_name\"].iloc[0]\n",
    "\n",
    "    # Normalize weights to sum to 100\n",
    "    total_weight = fund_holdings[\"weight_pct\"].sum()\n",
    "    weights      = fund_holdings[\"weight_pct\"] / total_weight * 100\n",
    "\n",
    "    # HHI = sum of squared weights\n",
    "    hhi = (weights ** 2).sum()\n",
    "\n",
    "    # Classify concentration\n",
    "    if hhi > 2500:\n",
    "        concentration = \"🔴 High\"\n",
    "    elif hhi > 1500:\n",
    "        concentration = \"🟡 Moderate\"\n",
    "    else:\n",
    "        concentration = \"🟢 Low\"\n",
    "\n",
    "    hhi_data.append({\n",
    "        \"scheme_code\":   fund_code,\n",
    "        \"scheme_name\":   scheme_name,\n",
    "        \"num_stocks\":    len(fund_holdings),\n",
    "        \"hhi_score\":     round(hhi, 2),\n",
    "        \"concentration\": concentration,\n",
    "    })\n",
    "\n",
    "hhi_df = pd.DataFrame(hhi_data).sort_values(\"hhi_score\", ascending=False)\n",
    "\n",
    "print(\"✅ HHI Concentration computed!\")\n",
    "print(\"\\n📊 Sector HHI Rankings (Higher = More Concentrated):\")\n",
    "print(hhi_df.to_string(index=False))\n",
    "\n",
    "# Save\n",
    "hhi_df.to_csv(str(BASE / \"hhi_concentration.csv\"), index=False)\n",
