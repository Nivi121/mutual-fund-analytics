    "# ── CHART 3: SIP Inflow Time Series ──────────────\n",
    "txn = pd.read_csv(PROC / \"investor_transactions_clean.csv\")\n",
    "txn[\"txn_date\"] = pd.to_datetime(txn[\"txn_date\"])\n",
    "\n",
    "# Filter SIP only and group by month\n",
    "sip = txn[txn[\"txn_type\"] == \"SIP\"].copy()\n",
    "sip[\"month\"] = sip[\"txn_date\"].dt.to_period(\"M\").dt.to_timestamp()\n",
    "sip_monthly = sip.groupby(\"month\")[\"amount\"].sum().reset_index()\n",
    "sip_monthly.columns = [\"month\", \"total_sip\"]\n",
    "\n",
    "# Find highest month\n",
    "max_row = sip_monthly.loc[sip_monthly[\"total_sip\"].idxmax()]\n",
    "\n",
    "fig = px.line(\n",
    "    sip_monthly,\n",
    "    x=\"month\",\n",
    "    y=\"total_sip\",\n",
    "    title=\"📈 Monthly SIP Inflow Trend\",\n",
    "    labels={\"month\": \"Month\", \"total_sip\": \"SIP Amount (₹)\"},\n",
    "    markers=True,\n",
    ")\n",
    "\n",
    "# Annotate highest point\n",
    "fig.add_annotation(\n",
    "    x=max_row[\"month\"],\n",
    "    y=max_row[\"total_sip\"],\n",
    "    text=f\"Peak: ₹{max_row['total_sip']:,.0f}\",\n",
