    "perf = perf.merge(funds[[\"scheme_code\", \"scheme_name\"]], on=\"scheme_code\")\n",
    "\n",
    "# Melt for grouped bar chart\n",
    "perf_melt = perf.melt(\n",
    "    id_vars=\"scheme_name\",\n",
    "    value_vars=[\"1m_return\", \"3m_return\", \"6m_return\", \"1y_return\"],\n",
    "    var_name=\"period\",\n",
    "    value_name=\"return_pct\"\n",
    ")\n",
    "\n",
    "period_labels = {\n",
    "    \"1m_return\": \"1 Month\",\n",
    "    \"3m_return\": \"3 Months\",\n",
    "    \"6m_return\": \"6 Months\",\n",
    "    \"1y_return\": \"1 Year\",\n",
    "}\n",
    "perf_melt[\"period\"] = perf_melt[\"period\"].map(period_labels)\n",
    "\n",
    "fig = px.bar(\n",
    "    perf_melt,\n",
    "    x=\"scheme_name\",\n",
    "    y=\"return_pct\",\n",
    "    color=\"period\",\n",
    "    barmode=\"group\",\n",
    "    title=\"📊 Fund Performance — Returns by Period\",\n",
    "    labels={\n",
    "        \"scheme_name\": \"Fund\",\n",
    "        \"return_pct\":  \"Return (%)\",\n",
    "        \"period\":      \"Period\"\n",
    "    },\n",
    ")\n",
    "fig.update_layout(height=500, xaxis_tickangle=-45)\n",
    "fig.write_html(str(CHARTS / \"chart8_performance.html\"))\n",
    "fig.show()\n",
    "print(\"✅ Chart 8 saved!\")"
