    "nav[\"nav_date\"]    = pd.to_datetime(nav[\"nav_date\"])\n",
    "\n",
    "# Reload funds\n",
    "funds = pd.read_csv(RAW / \"fund_master.csv\")\n",
    "funds[\"scheme_code\"] = funds[\"scheme_code\"].astype(int)\n",
    "\n",
    "# Merge\n",
    "nav_merged = nav.merge(funds[[\"scheme_code\", \"scheme_name\"]], on=\"scheme_code\")\n",
    "\n",
