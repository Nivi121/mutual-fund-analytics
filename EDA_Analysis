    "# ── CHART 4: Category Inflow Heatmap ──────────────\n",
    "# Merge transactions with fund categories\n",
    "txn_cat = txn.merge(funds[[\"scheme_code\", \"sub_category\"]], on=\"scheme_code\")\n",
    "txn_cat[\"month\"] = txn_cat[\"txn_date\"].dt.strftime(\"%b %Y\")\n",
    "txn_cat[\"month_num\"] = txn_cat[\"txn_date\"].dt.to_period(\"M\")\n",
    "\n",
    "# Pivot table — category vs month\n",
    "pivot = txn_cat.groupby([\"sub_category\", \"month_num\"])[\"amount\"].sum().reset_index()\n",
    "pivot[\"month\"] = pivot[\"month_num\"].dt.strftime(\"%b %Y\")\n",
    "pivot = pivot.pivot(index=\"sub_category\", columns=\"month\", values=\"amount\").fillna(0)\n",
    "\n",
    "plt.figure(figsize=(16, 5))\n",
    "sns.heatmap(\n",
    "    pivot,\n",
    "    cmap=\"YlOrRd\",\n",
    "    annot=True,\n",
    "    fmt=\".0f\",\n",
    "    linewidths=0.5,\n",
    "    cbar_kws={\"label\": \"Inflow (₹)\"}\n",
    ")\n",
    "plt.title(\" Category Inflow Heatmap — Month vs Sub-Category\", fontsize=13)\n",
    "plt.xlabel(\"Month\")\n",
    "plt.ylabel(\"Fund Category\")\n",
    "plt.xticks(rotation=45, ha=\"right\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(str(CHARTS / \"chart4_category_heatmap.png\"), dpi=150)\n",
    "plt.show()\n",
    "print(\"✅ Chart 4 saved!\")"
   ]
