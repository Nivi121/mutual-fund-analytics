    "# ── CHART 10: Top Stock Holdings ──────────────\n",
    "holdings = pd.read_csv(RAW / \"portfolio_holdings.csv\")\n",
    "\n",
    "top_stocks = holdings.groupby(\"stock_name\")[\"weight_pct\"].mean().reset_index()\n",
    "top_stocks = top_stocks.sort_values(\"weight_pct\", ascending=True)\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.barh(\n",
    "    top_stocks[\"stock_name\"],\n",
    "    top_stocks[\"weight_pct\"],\n",
    "    color=sns.color_palette(\"viridis\", len(top_stocks))\n",
    ")\n",
    "plt.title(\"Average Stock Weight Across All Funds\", fontsize=13)\n",
    "plt.xlabel(\"Average Weight (%)\")\n",
    "plt.ylabel(\"Stock\")\n",
    "for i, v in enumerate(top_stocks[\"weight_pct\"]):\n",
    "    plt.text(v + 0.1, i, f\"{v:.1f}%\", va=\"center\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(str(CHARTS / \"chart10_top_holdings.png\"), dpi=150)\n",
    "plt.show()\n",
    "print(\"✅ Chart 10 saved!\")"
   ]
