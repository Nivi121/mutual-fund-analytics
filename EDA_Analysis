    "# ── CHART 9: AUM Trend Over Time ──────────────\n",
    "aum = pd.read_csv(RAW / \"aum_history.csv\")\n",
    "aum[\"date\"] = pd.to_datetime(aum[\"date\"])\n",
    "aum = aum.merge(funds[[\"scheme_code\", \"scheme_name\"]], on=\"scheme_code\")\n",
    "\n",
    "fig = px.line(\n",
    "    aum,\n",
    "    x=\"date\",\n",
    "    y=\"aum_crore\",\n",
    "    color=\"scheme_name\",\n",
    "    title=\"📈 AUM Growth Over Time — All Funds\",\n",
    "    labels={\n",
    "        \"date\":        \"Date\",\n",
    "        \"aum_crore\":   \"AUM (₹ Crore)\",\n",
    "        \"scheme_name\": \"Fund\"\n",
    "    },\n",
    "    markers=True,\n",
    ")\n",
    "fig.update_layout(height=500)\n",
    "fig.write_html(str(CHARTS / \"chart9_aum_trend.html\"))\n",
    "fig.show()\n",
    "print(\"✅ Chart 9 saved!\")"
   ]
