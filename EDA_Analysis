    "# ── CHART 1: NAV Trend for All Funds ──────────────\n",
    "nav_merged = nav.merge(funds[[\"scheme_code\", \"scheme_name\"]], on=\"scheme_code\")\n",
    "\n",
    "# Make sure date is proper datetime\n",
    "nav_merged[\"nav_date\"] = pd.to_datetime(nav_merged[\"nav_date\"])\n",
    "\n",
    "# Check data\n",
    "print(f\"Date range: {nav_merged['nav_date'].min()} → {nav_merged['nav_date'].max()}\")\n",
    "print(f\"Total rows: {len(nav_merged)}\")\n",
    "print(nav_merged.head(3))\n",
    "\n",
    "fig = px.line(\n",
    "    nav_merged,\n",
    "    x=\"nav_date\",\n",
    "    y=\"nav_value\",\n",
    "    color=\"scheme_name\",\n",
    "    title=\"📈 Daily NAV Trend — All Funds (2025–2026)\",\n",
    "    labels={\n",
    "        \"nav_date\":    \"Date\",\n",
    "        \"nav_value\":   \"NAV (₹)\",\n",
    "        \"scheme_name\": \"Fund\"\n",
    "    },\n",
    ")\n",
    "\n",
    "# Highlight bull run period\n",
    "fig.add_vrect(\n",
    "    x0=\"2025-06-01\", x1=\"2025-09-30\",\n",
    "    fillcolor=\"green\", opacity=0.1,\n",
    "    annotation_text=\"Bull Run\",\n",
    "    annotation_position=\"top left\"\n",
    ")\n",
    "\n",
    "# Highlight correction period\n",
    "fig.add_vrect(\n",
    "    x0=\"2025-10-01\", x1=\"2025-12-31\",\n",
    "    fillcolor=\"red\", opacity=0.1,\n",
    "    annotation_text=\"Correction\",\n",
    "    annotation_position=\"top left\"\n",
    ")\n",
    "\n",
    "fig.update_layout(height=500, hovermode=\"x unified\")\n",
    "fig.write_html(str(CHARTS / \"chart1_nav_trend.html\"))\n",
    "fig.show()\n",
    "print(\"✅ Chart 1 done!\")"
   ]
