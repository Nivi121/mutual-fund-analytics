    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import plotly.express as px\n",
    "import plotly.graph_objects as go\n",
    "import pathlib\n",
    "import warnings\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "\n",
    "# Paths\n",
    "BASE   = pathlib.Path().resolve()\n",
    "RAW    = BASE / \"data\" / \"raw\"\n",
    "PROC   = BASE / \"data\" / \"processed\"\n",
    "CHARTS = BASE / \"reports\"\n",
    "CHARTS.mkdir(exist_ok=True)\n",
    "\n",
    "# Load datasets\n",
    "nav      = pd.read_csv(PROC / \"nav_history_clean.csv\")\n",
    "funds    = pd.read_csv(RAW  / \"fund_master.csv\")\n",
    "txn      = pd.read_csv(PROC / \"investor_transactions_clean.csv\")\n",
    "aum      = pd.read_csv(RAW  / \"aum_history.csv\")\n",
    "returns  = pd.read_csv(RAW  / \"scheme_returns.csv\")\n",
    "holdings = pd.read_csv(RAW  / \"portfolio_holdings.csv\")\n",
    "risk     = pd.read_csv(RAW  / \"risk_metrics.csv\")\n",
    "\n",
    "# Parse dates\n",
    "nav[\"nav_date\"] = pd.to_datetime(nav[\"nav_date\"])\n",
    "txn[\"txn_date\"] = pd.to_datetime(txn[\"txn_date\"])\n",
    "aum[\"date\"]     = pd.to_datetime(aum[\"date\"])\n",
    "\n",
    "print(\"✅ All libraries loaded!\")\n",
    "print(f\"   NAV records  : {len(nav):,}\")\n",
    "print(f\"   Transactions : {len(txn):,}\")\n",
    "print(f\"   AUM records  : {len(aum):,}\")\n",
    "print(f\"   Funds        : {len(funds):,}\")"
   ]
