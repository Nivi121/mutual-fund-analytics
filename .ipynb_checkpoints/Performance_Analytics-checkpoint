    "# ── TASK 3: Sharpe Ratio ──────────────────────\n",
    "# Sharpe = (Rp - Rf) / Std(Rp) × √252\n",
    "# Rf = 6.5% (RBI repo rate proxy)\n",
    "\n",
    "RF = 0.065  # Risk-free rate\n",
    "TRADING_DAYS = 252\n",
    "\n",
    "sharpe_data = []\n",
    "\n",
    "for fund_code in nav_returns[\"scheme_code\"].unique():\n",
    "    fund_data = nav_returns[nav_returns[\"scheme_code\"] == fund_code].sort_values(\"nav_date\")\n",
    "    scheme_name = fund_data[\"scheme_name\"].iloc[0]\n",
    "    \n",
    "    # Daily returns\n",
    "    daily_rets = fund_data[\"daily_return\"].values\n",
    "    \n",
    "    # Annualized metrics\n",
    "    annual_return = (1 + daily_rets.mean()) ** TRADING_DAYS - 1\n",
    "    annual_std    = daily_rets.std() * np.sqrt(TRADING_DAYS)\n",
    "    \n",
    "    # Sharpe Ratio\n",
    "    sharpe = (annual_return - RF) / annual_std if annual_std > 0 else 0\n",
    "    \n",
    "    sharpe_data.append({\n",
    "        \"scheme_code\":      fund_code,\n",
    "        \"scheme_name\":      scheme_name,\n",
    "        \"annual_return_%\":  round(annual_return * 100, 2),\n",
    "        \"annual_std_%\":     round(annual_std * 100, 2),\n",
    "        \"sharpe_ratio\":     round(sharpe, 3),\n",
    "    })\n",
    "\n",
    "sharpe_df = pd.DataFrame(sharpe_data).sort_values(\"sharpe_ratio\", ascending=False)\n",
    "\n",
    "print(\"✅ Sharpe Ratio computed!\")\n",
    "print(\"\\n📊 Sharpe Ratio Rankings (Higher is Better):\")\n",
    "print(sharpe_df.to_string(index=False))\n",
    "\n",
    "# Save\n",
    "sharpe_df.to_csv(str(BASE / \"sharpe_ratio.csv\"), index=False)\n",
    "print(\"\\n💾 Saved to sharpe_ratio.csv\")"
   ]
