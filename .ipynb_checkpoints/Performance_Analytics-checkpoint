    "# ── TASK 4: Sortino Ratio ─────────────────────\n",
    "# Sortino = (Rp - Rf) / Std(Rp_downside) × √252\n",
    "# Only penalizes downside volatility\n",
    "\n",
    "sortino_data = []\n",
    "\n",
    "for fund_code in nav_returns[\"scheme_code\"].unique():\n",
    "    fund_data = nav_returns[nav_returns[\"scheme_code\"] == fund_code].sort_values(\"nav_date\")\n",
    "    scheme_name = fund_data[\"scheme_name\"].iloc[0]\n",
    "    \n",
    "    daily_rets = fund_data[\"daily_return\"].values\n",
    "    \n",
    "    # Annualized return\n",
    "    annual_return = (1 + daily_rets.mean()) ** TRADING_DAYS - 1\n",
    "    \n",
    "    # Downside standard deviation (only negative returns)\n",
    "    downside_rets = daily_rets[daily_rets < 0]\n",
    "    downside_std = downside_rets.std() * np.sqrt(TRADING_DAYS) if len(downside_rets) > 0 else 0\n",
    "    \n",
    "    # Sortino Ratio\n",
    "    sortino = (annual_return - RF) / downside_std if downside_std > 0 else 0\n",
    "    \n",
    "    sortino_data.append({\n",
    "        \"scheme_code\":      fund_code,\n",
    "        \"scheme_name\":      scheme_name,\n",
    "        \"annual_return_%\":  round(annual_return * 100, 2),\n",
    "        \"downside_std_%\":   round(downside_std * 100, 2),\n",
    "        \"sortino_ratio\":    round(sortino, 3),\n",
    "    })\n",
    "\n",
    "sortino_df = pd.DataFrame(sortino_data).sort_values(\"sortino_ratio\", ascending=False)\n",
    "\n",
    "print(\"✅ Sortino Ratio computed!\")\n",
    "print(\"\\n📊 Sortino Ratio Rankings (Higher is Better):\")\n",
    "print(sortino_df.to_string(index=False))\n",
    "\n",
    "# Save\n",
    "sortino_df.to_csv(str(BASE / \"sortino_ratio.csv\"), index=False)\n",
    "print(\"\\n💾 Saved to sortino_ratio.csv\")"
   ]
