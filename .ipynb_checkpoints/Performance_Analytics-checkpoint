    "# ── TASK 1: Compute Daily Returns ──────────────\n",
    "# daily_return = (nav_t / nav_t-1) - 1\n",
    "\n",
    "# Sort by scheme and date first\n",
    "nav = nav.sort_values([\"scheme_code\", \"nav_date\"]).reset_index(drop=True)\n",
    "\n",
    "# Calculate daily returns per fund\n",
    "nav[\"daily_return\"] = nav.groupby(\"scheme_code\")[\"nav_value\"].pct_change()\n",
    "\n",
    "# Remove the first NaN for each fund\n",
    "nav_returns = nav.dropna(subset=[\"daily_return\"])\n",
    "\n",
    "print(f\"✅ Daily returns calculated!\")\n",
    "print(f\"   Total return records : {len(nav_returns):,}\")\n",
    "print(f\"\\n   Return statistics:\")\n",
    "print(f\"   Mean daily return    : {nav_returns['daily_return'].mean():.6f}\")\n",
    "print(f\"   Std dev daily return : {nav_returns['daily_return'].std():.6f}\")\n",
    "print(f\"   Min daily return     : {nav_returns['daily_return'].min():.6f}\")\n",
    "print(f\"   Max daily return     : {nav_returns['daily_return'].max():.6f}\")\n",
    "\n",
    "# Plot distribution\n",
    "plt.figure(figsize=(12, 4))\n",
    "\n",
    "plt.subplot(1, 2, 1)\n",
    "plt.hist(nav_returns['daily_return'], bins=50, edgecolor='black', alpha=0.7)\n",
    "plt.xlabel(\"Daily Return\")\n",
    "plt.ylabel(\"Frequency\")\n",
    "plt.title(\"Distribution of Daily Returns — All Funds\")\n",
    "plt.grid(alpha=0.3)\n",
    "\n",
    "plt.subplot(1, 2, 2)\n",
    "stats.probplot(nav_returns['daily_return'], dist=\"norm\", plot=plt)\n",
    "plt.title(\"Q-Q Plot — Normality Check\")\n",
    "plt.grid(alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(str(CHARTS / \"daily_returns_distribution.png\"), dpi=150)\n",
    "plt.show()\n",
    "print(\"✅ Return distribution chart saved!\")"
   ]
