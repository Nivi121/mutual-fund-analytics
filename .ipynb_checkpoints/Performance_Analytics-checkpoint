    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import plotly.express as px\n",
    "from scipy import stats\n",
    "import pathlib\n",
    "import warnings\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "\n",
    "# Paths\n",
    "BASE   = pathlib.Path().resolve()\n",
    "RAW    = BASE / \"data\" / \"raw\"\n",
    "PROC   = BASE / \"data\" / \"processed\"\n",
    "CHARTS = BASE / \"reports\"\n",
    "\n",
    "# Load NAV data\n",
    "nav = pd.read_csv(PROC / \"nav_history_clean.csv\")\n",
    "nav.columns = [\"nav_date\", \"scheme_code\", \"nav_value\"]\n",
    "nav[\"scheme_code\"] = nav[\"scheme_code\"].astype(int)\n",
    "nav[\"nav_value\"]   = nav[\"nav_value\"].astype(float)\n",
    "nav[\"nav_date\"]    = pd.to_datetime(nav[\"nav_date\"])\n",
    "\n",
    "# Load fund master\n",
    "funds = pd.read_csv(RAW / \"fund_master.csv\")\n",
    "funds[\"scheme_code\"] = funds[\"scheme_code\"].astype(int)\n",
    "\n",
    "# Load benchmark\n",
    "bench = pd.read_csv(RAW / \"benchmark_index.csv\")\n",
    "bench[\"date\"] = pd.to_datetime(bench[\"date\"])\n",
    "\n",
    "# Merge nav with fund names\n",
    "nav = nav.merge(funds[[\"scheme_code\", \"scheme_name\"]], on=\"scheme_code\")\n",
    "\n",
    "print(\"✅ Setup complete!\")\n",
    "print(f\"   NAV records  : {len(nav):,}\")\n",
    "print(f\"   Funds        : {nav['scheme_name'].nunique()}\")\n",
    "print(f\"   Date range   : {nav['nav_date'].min().date()} → {nav['nav_date'].max().date()}\")"
   ]
