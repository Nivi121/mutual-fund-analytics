    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import pathlib\n",
    "import warnings\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "\n",
    "# Paths\n",
    "BASE   = pathlib.Path().resolve()\n",
    "RAW    = BASE / \"data\" / \"raw\"\n",
    "PROC   = BASE / \"data\" / \"processed\"\n",
    "CHARTS = BASE / \"reports\"\n",
    "\n",
    "# Load data\n",
    "nav = pd.read_csv(PROC / \"nav_history_clean.csv\")\n",
    "nav.columns = [\"nav_date\", \"scheme_code\", \"nav_value\"]\n",
    "nav[\"scheme_code\"] = nav[\"scheme_code\"].astype(int)\n",
    "nav[\"nav_value\"]   = nav[\"nav_value\"].astype(float)\n",
    "nav[\"nav_date\"]    = pd.to_datetime(nav[\"nav_date\"])\n",
    "\n",
    "funds = pd.read_csv(RAW / \"fund_master.csv\")\n",
    "funds[\"scheme_code\"] = funds[\"scheme_code\"].astype(int)\n",
    "\n",
    "txn = pd.read_csv(PROC / \"investor_transactions_clean.csv\")\n",
    "txn[\"txn_date\"] = pd.to_datetime(txn[\"txn_date\"])\n",
    "\n",
    "holdings = pd.read_csv(RAW / \"portfolio_holdings.csv\")\n",
    "\n",
    "# Merge nav with fund names\n",
    "nav = nav.merge(funds[[\"scheme_code\",\"scheme_name\",\"risk_grade\"]], on=\"scheme_code\")\n",
    "\n",
    "# Compute daily returns\n",
    "nav = nav.sort_values([\"scheme_code\",\"nav_date\"])\n",
    "nav[\"daily_return\"] = nav.groupby(\"scheme_code\")[\"nav_value\"].pct_change()\n",
    "nav_returns = nav.dropna(subset=[\"daily_return\"])\n",
    "\n",
    "print(\"✅ Setup complete!\")\n",
    "print(f\"   NAV records  : {len(nav_returns):,}\")\n",
    "print(f\"   Funds        : {nav_returns['scheme_name'].nunique()}\")\n",
    "print(f\"   Transactions : {len(txn):,}\")"
   ]
