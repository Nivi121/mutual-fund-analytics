    "# ── TASK 3: Investor Cohort Analysis ──────────────\n",
    "# Group investors by first transaction year\n",
    "\n",
    "# Add year column\n",
    "txn[\"year\"] = txn[\"txn_date\"].dt.year\n",
    "\n",
    "# Find first transaction year per investor\n",
    "first_txn = txn.groupby(\"transaction_id\")[\"txn_date\"].min().reset_index()\n",
    "first_txn[\"cohort_year\"] = first_txn[\"txn_date\"].dt.year\n",
    "first_txn.columns = [\"transaction_id\", \"first_date\", \"cohort_year\"]\n",
    "\n",
    "# Merge cohort back to transactions\n",
    "txn_cohort = txn.merge(first_txn[[\"transaction_id\", \"cohort_year\"]], on=\"transaction_id\")\n",
    "\n",
    "# Compute stats per cohort\n",
    "cohort_stats = txn_cohort.groupby(\"cohort_year\").agg(\n",
    "    total_investors   = (\"transaction_id\", \"nunique\"),\n",
    "    avg_sip_amount    = (\"amount\", \"mean\"),\n",
    "    total_invested    = (\"amount\", \"sum\"),\n",
    "    total_txns        = (\"transaction_id\", \"count\"),\n",
    ").reset_index()\n",
    "cohort_stats[\"avg_sip_amount\"] = cohort_stats[\"avg_sip_amount\"].round(2)\n",
    "cohort_stats[\"total_invested\"] = cohort_stats[\"total_invested\"].round(2)\n",
    "\n",
    "print(\"✅ Cohort Analysis complete!\")\n",
    "print(\"\\n📊 Investor Cohort Summary:\")\n",
    "print(cohort_stats.to_string(index=False))\n",
    "\n",
    "# Top fund per cohort\n",
    "txn_cohort_funds = txn_cohort.merge(\n",
    "    funds[[\"scheme_code\", \"scheme_name\"]], on=\"scheme_code\")\n",
    "top_fund = txn_cohort_funds.groupby(\n",
    "    [\"cohort_year\", \"scheme_name\"])[\"amount\"].sum().reset_index()\n",
    "top_fund = top_fund.loc[top_fund.groupby(\"cohort_year\")[\"amount\"].idxmax()]\n",
    "top_fund.columns = [\"cohort_year\", \"top_fund\", \"amount\"]\n",
    "\n",
    "print(\"\\n🏆 Top Fund Preference per Cohort:\")\n",
    "print(top_fund[[\"cohort_year\", \"top_fund\"]].to_string(index=False))\n",
    "\n",
    "# Plot\n",
    "plt.figure(figsize=(10, 5))\n",
    "plt.bar(cohort_stats[\"cohort_year\"].astype(str),\n",
    "        cohort_stats[\"total_invested\"],\n",
    "        color=[\"#2196F3\", \"#4CAF50\", \"#FF9800\"])\n",
    "plt.title(\"💰 Total Amount Invested by Cohort Year\", fontsize=13)\n",
    "plt.xlabel(\"Cohort Year\")\n",
    "plt.ylabel(\"Total Invested (₹)\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(str(CHARTS / \"cohort_analysis.png\"), dpi=150)\n",
    "plt.show()\n",
    "print(\"✅ Cohort chart saved!\")"
   ]
