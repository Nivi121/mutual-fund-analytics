    "# ── TASK 2: Compute CAGR ──────────────────────\n",
    "# CAGR = (NAV_end / NAV_start) ^ (1/n) - 1\n",
    "\n",
    "# Get latest NAV for each fund\n",
    "latest_nav = nav_returns.sort_values(\"nav_date\").groupby(\"scheme_code\").tail(1)\n",
    "\n",
    "# Compute CAGR for different periods (approx using available data)\n",
    "cagr_data = []\n",
    "\n",
    "for fund_code in nav_returns[\"scheme_code\"].unique():\n",
    "    fund_data = nav_returns[nav_returns[\"scheme_code\"] == fund_code].sort_values(\"nav_date\")\n",
    "    scheme_name = fund_data[\"scheme_name\"].iloc[0]\n",
    "    \n",
    "    if len(fund_data) > 0:\n",
    "        start_nav = fund_data.iloc[0][\"nav_value\"]\n",
    "        end_nav   = fund_data.iloc[-1][\"nav_value\"]\n",
    "        start_date = pd.to_datetime(fund_data.iloc[0][\"nav_date\"])\n",
    "        end_date   = pd.to_datetime(fund_data.iloc[-1][\"nav_date\"])\n",
    "        \n",
    "        years = (end_date - start_date).days / 365.25\n",
    "        cagr = ((end_nav / start_nav) ** (1/years) - 1) * 100 if years > 0 else 0\n",
    "        \n",
    "        cagr_data.append({\n",
    "            \"scheme_code\":   fund_code,\n",
    "            \"scheme_name\":   scheme_name,\n",
    "            \"start_nav\":     round(start_nav, 4),\n",
    "            \"end_nav\":       round(end_nav, 4),\n",
    "            \"years\":         round(years, 2),\n",
    "            \"cagr_%\":        round(cagr, 2),\n",
    "        })\n",
    "\n",
    "cagr_df = pd.DataFrame(cagr_data).sort_values(\"cagr_%\", ascending=False)\n",
    "\n",
    "print(\"✅ CAGR computed for all funds!\")\n",
    "print(\"\\n📊 CAGR Comparison Table:\")\n",
    "print(cagr_df.to_string(index=False))\n",
    "\n",
    "# Save to CSV\n",
    "cagr_df.to_csv(str(BASE / \"cagr_comparison.csv\"), index=False)\n",
    "print(\"\\n💾 Saved to cagr_comparison.csv\")"
