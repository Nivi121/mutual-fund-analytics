    "# ── TASK 5: Alpha & Beta via OLS Regression ──\n",
    "# Beta = slope, Alpha = intercept × 252\n",
    "\n",
    "# Compute benchmark returns\n",
    "bench = bench.sort_values(\"date\")\n",
    "bench[\"daily_return\"] = bench[\"close\"].pct_change()\n",
    "bench_returns = bench[[\"date\", \"daily_return\"]].dropna()\n",
    "bench_returns.columns = [\"nav_date\", \"benchmark_return\"]\n",
    "\n",
    "# Merge fund returns with benchmark\n",
    "nav_with_bench = nav_returns.merge(\n",
    "    bench_returns,\n",
    "    on=\"nav_date\",\n",
    "    how=\"inner\"\n",
    ")\n",
    "\n",
    "alpha_beta_data = []\n",
    "\n",
    "for fund_code in nav_with_bench[\"scheme_code\"].unique():\n",
    "    fund_data = nav_with_bench[nav_with_bench[\"scheme_code\"] == fund_code]\n",
    "    scheme_name = fund_data[\"scheme_name\"].iloc[0]\n",
    "    \n",
    "    X = fund_data[\"benchmark_return\"].values\n",
    "    y = fund_data[\"daily_return\"].values\n",
    "    \n",
    "    # OLS Regression\n",
    "    slope, intercept, r_value, p_value, std_err = stats.linregress(X, y)\n",
    "    \n",
    "    # Annualize Alpha\n",
    "    alpha = intercept * TRADING_DAYS * 100\n",
    "    \n",
    "    alpha_beta_data.append({\n",
    "        \"scheme_code\":    fund_code,\n",
    "        \"scheme_name\":    scheme_name,\n",
    "        \"beta\":           round(slope, 3),\n",
    "        \"alpha_%\":        round(alpha, 2),\n",
    "        \"r_squared\":      round(r_value**2, 3),\n",
    "        \"p_value\":        round(p_value, 4),\n",
    "    })\n",
    "\n",
    "alpha_beta_df = pd.DataFrame(alpha_beta_data).sort_values(\"alpha_%\", ascending=False)\n",
    "\n",
    "print(\"✅ Alpha & Beta computed via OLS!\")\n",
    "print(\"\\n📊 Alpha & Beta Rankings:\")\n",
    "print(alpha_beta_df.to_string(index=False))\n",
    "\n",
    "# Save\n",
    "alpha_beta_df.to_csv(str(BASE / \"alpha_beta.csv\"), index=False)\n",
    "print(\"\\n💾 Saved to alpha_beta.csv\")"
   ]
